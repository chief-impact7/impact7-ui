{
  "name": "@impact7/ui",
  "version": "0.3.0",
  "type": "module",
  "description": "impact7 에코시스템 공유 React 컴포넌트 라이브러리 (design-tokens SSoT + a11y 기반). React 앱은 직접 import, 바닐라/Svelte 앱은 mount 어댑터로 부분 마운트.",
  "files": [
    "dist",
    "index.d.ts"
  ],
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/impact7-ui.js"
    },
    "./mount": "./dist/mount.js",
    "./icons": "./dist/icons.js",
    "./styles.css": "./dist/impact7-ui.css"
  },
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "build": "npm run build:tokens && vite build",
    "dev": "npm run build:tokens && vite",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1"
  },
  "license": "UNLICENSED",
  "private": true
}
