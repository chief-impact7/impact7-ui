{
  "name": "@impact7/ui",
  "version": "0.9.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chief-impact7/impact7-ui.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "impact7 에코시스템 공유 React 컴포넌트 라이브러리 (design-tokens SSoT + a11y 기반). React 앱은 직접 import, 바닐라/Svelte 앱은 mount 어댑터로 부분 마운트.",
  "files": [
    "dist",
    "index.d.ts",
    "icons.d.ts",
    "icons-named.d.ts",
    "THIRD_PARTY_NOTICES.md"
  ],
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./dist/impact7-ui.js"
    },
    "./mount": "./dist/mount.js",
    "./icons": {
      "types": "./icons.d.ts",
      "default": "./dist/icons.js"
    },
    "./icons/named": {
      "types": "./icons-named.d.ts",
      "default": "./dist/icons-named.js"
    },
    "./styles.css": "./dist/impact7-ui.css"
  },
  "scripts": {
    "build:icons": "node scripts/build-icons.mjs",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build": "npm run build:icons && npm run build:tokens && NODE_ENV=production vite build",
    "dev": "npm run build:icons && npm run build:tokens && vite",
    "test": "NODE_ENV=development npm run build && node --test",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^7.3.1"
  },
  "license": "MIT"
}
